# MAGMOM 맵 (magmom_incar에서 가져온 매핑)
MAGMOM_MAP = {
    # 3d 전이금속
    'Sc': 1.0,  # 스칸듐
    'Mn': 5.0,  # 망간
    'Fe': 3.0,  # 철
    'Co': 2.0,  # 코발트
    'Ni': 1.0,  # 니켈
    
    # 4d 전이금속
    'Y': 1.0,   # 이트륨
    'Pd': 1.0,  # 팔라듐
    
    # 란타넘족
    'Eu': 9.0,  # 유로퓸
    'Gd': 8.0,  # 가돌리늄
    'Yb': 1.0,  # 이터븀
    'Lu': 1.0,  # 루테튬
    
    # 악티늄족
    'Pu': 3.0   # 플루토늄
}

def read_poscar_elements(poscar_path):
    with open(poscar_path, 'r') as f:
        lines = f.readlines()
    elements = lines[5].split()
    if len(elements) != len(set(elements)):
        print("sort_poscar")
        return None
    return elements

def read_poscar_counts(poscar_path):
    with open(poscar_path, 'r') as f:
        lines = f.readlines()
    elements = lines[5].split()
    counts = list(map(int, lines[6].split()))
    return elements, counts

def read_potcar_elements(potcar_path):
    result = subprocess.run(["grep", "PAW_PBE", potcar_path], capture_output=True, text=True)
    lines = result.stdout.split('\n')
    
    elements = []
    seen = set()
    for line in lines:
        match = re.search(r'PAW_PBE\s+(\w+)', line)
        if match:
            element = match.group(1)
            if element not in seen:
                elements.append(element)
                seen.add(element)
    
    return elements

def read_incar_magmom(incar_path):
    try:
        with open(incar_path, 'r') as f:
            lines = f.readlines()
        
        for line in lines:
            stripped = line.strip()
            if stripped.startswith("MAGMOM") and not stripped.startswith("#"):
                # MAGMOM = 2*3.0 1*2.0 1*0.0 형태에서 값들 추출
                magmom_part = stripped.split('=', 1)[1].strip()
                return magmom_part
        return None
    except FileNotFoundError:
        return None

def check_compatibility(poscar_path="POSCAR", potcar_path="POTCAR", incar_path="INCAR"):
    poscar_elements = read_poscar_elements(poscar_path)
    if poscar_elements is None:
        return
    
    # POTCAR 호환성 검사
    print("=== POTCAR 호환성 검사 ===")
    expected_potcar_elements = []
    for element in poscar_elements:
        if element in POTCAR_MAP:
            expected_potcar_elements.append(POTCAR_MAP[element])
        else:
            print(f"No POTCAR mapping found for element: {element}")
            return
    
    actual_potcar_elements = read_potcar_elements(potcar_path)
    
    if expected_potcar_elements == actual_potcar_elements:
        print("POTCAR: Compatible")
    else:
        print("POTCAR: Incompatible")
        print(f"Expected: {expected_potcar_elements}")
        print(f"Actual: {actual_potcar_elements}")
    
    # MAGMOM 호환성 검사
    print("\n=== MAGMOM 호환성 검사 ===")
    elements, counts = read_poscar_counts(poscar_path)
    
    # 예상되는 MAGMOM 값 계산
    expected_magmom_parts = []
    for elem, count in zip(elements, counts):
        magmom_value = MAGMOM_MAP.get(elem, 0.0)
        expected_magmom_parts.append(f"{count}*{magmom_value}")
    
    expected_magmom = ' '.join(expected_magmom_parts)
    
    # 실제 INCAR에서 MAGMOM 값 읽기
    actual_magmom = read_incar_magmom(incar_path)
    
    if actual_magmom is None:
        print("MAGMOM: No MAGMOM line found in INCAR")
    elif expected_magmom == actual_magmom:
        print("MAGMOM: Compatible")
    else:
        print("MAGMOM: Incompatible")
        print(f"Expected: {expected_magmom}")
        print(f"Actual: {actual_magmom}")
    
    # 전체 호환성 요약
    potcar_ok = expected_potcar_elements == actual_potcar_elements
    magmom_ok = actual_magmom is not None and expected_magmom == actual_magmom
    
    print(f"\n=== 전체 호환성 요약 ===")
    print(f"POTCAR: {'✓' if potcar_ok else '✗'}")
    print(f"MAGMOM: {'✓' if magmom_ok else '✗'}")
    
    if potcar_ok and magmom_ok:
        print("Overall: Compatible")
    else:
        print("Overall: Incompatible")

if __name__ == "__main__":
    check_compatibility()

